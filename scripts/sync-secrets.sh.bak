#!/bin/bash
# scripts/sync-secrets.sh
# Usage: ./scripts/sync-secrets.sh infra/terraform.tfvars

set -e

ENV="mc-prod"
FILE=$1

if [ -z "$FILE" ]; then
    echo "Usage: $0 <path-to-tfvars-file>"
    exit 1
fi

echo "Syncing secrets from $FILE to GitHub environment: $ENV..."

# Helper to set secret/variable
set_gh() {
    local key=$1
    local val=$2
    
    # Check if it's likely a secret (contains 'token', 'secret', 'password', 'key')
    if [[ "$key" =~ (token|secret|password|key|auth) ]]; then
        echo "Setting secret: $key"
        gh secret set "$key" --env "$ENV" --body "$val"
    else
        echo "Setting variable: $key"
        gh variable set "$key" --env "$ENV" --body "$val"
    fi
}

# Parse the tfvars file (handles basic key = "value" pairs)
while IFS='=' read -r key val || [ -n "$key" ]; do
    # Skip comments and empty lines
    [[ "$key" =~ ^#.*$ ]] && continue
    [[ -z "$key" ]] && continue
    
    # Trim whitespace and quotes
    key=$(echo "$key" | xargs)
    val=$(echo "$val" | xargs | sed 's/^"//;s/"$//')
    
    set_gh "$key" "$val"
done < "$FILE"

echo "✅ Sync complete! Your GitHub Actions environment '$ENV' is now matching your local .tfvars."
